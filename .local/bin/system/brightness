#!/bin/sh

file="/sys/class/backlight/amdgpu_bl2/brightness"
send_notification() {
	brightness=$(cat $file)
	brightness_percentage=$(( brightness * 100 / 65535 ))
	luft "Brightness: $brightness_percentage%"
}

case $1 in
up)
	echo $(( $(cat $file) + 3276 )) | ssu tee $file > /dev/null
	send_notification
	;;
down)
	echo $(( $(cat $file) - 3276 )) | ssu tee $file > /dev/null
	send_notification
	;;
esac

